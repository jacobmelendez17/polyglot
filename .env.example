# Copy to .env for local dev. Never commit real values.
POSTGRES_USER=polyglot
POSTGRES_PASSWORD=polyglot_dev_only
POSTGRES_DB=polyglot
DATABASE_URL=postgresql+psycopg://polyglot:polyglot_dev_only@db:5432/polyglot
REDIS_URL=redis://redis:6379/0
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000
AUTH_JWKS_URL=http://web:3000/api/auth/jwks   # Auth.js JWKS (slice 1c)
AUTH_AUDIENCE=polyglot-api
AUTH_ISSUER=polyglot-web
NEXT_PUBLIC_API_URL=http://localhost:8000
