# Copy to .env for local dev. Never commit real values.
POSTGRES_USER=lengua
POSTGRES_PASSWORD=lengua_dev_only
POSTGRES_DB=lengua
DATABASE_URL=postgresql+psycopg://lengua:lengua_dev_only@db:5432/lengua
REDIS_URL=redis://redis:6379/0
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000
AUTH_JWKS_URL=http://web:3000/api/auth/jwks   # Auth.js JWKS (slice 1c)
AUTH_AUDIENCE=lengua-api
AUTH_ISSUER=lengua-web
NEXT_PUBLIC_API_URL=http://localhost:8000
